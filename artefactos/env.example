# ==============================================================
# .env.example — Plantilla de Variables de Entorno
# Proyecto Final AI/LLM Solution Architect
# ==============================================================
# INSTRUCCIONES:
#   1. Copia este archivo:  cp .env.example .env
#   2. Rellena los valores reales en .env
#   3. NUNCA commitees el archivo .env al repositorio
#   4. Verifica que .gitignore incluye: .env
# ==============================================================


# ──────────────────────────────────────────────────────────────
# ENTORNO Y CONFIGURACIÓN GENERAL
# ──────────────────────────────────────────────────────────────

# Entorno de ejecución
# Valores válidos: development | staging | production | testing
ENVIRONMENT=development

# Host y puerto de la API
API_HOST=0.0.0.0
API_PORT=8000

# Nombre del proyecto (usado en logs y trazas)
PROJECT_NAME=ai-llm-project

# Nivel de logging
# Valores válidos: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Usar DEBUG solo en development — nunca en producción
LOG_LEVEL=INFO

# Versión de la aplicación (Semantic Versioning)
APP_VERSION=1.0.0


# ──────────────────────────────────────────────────────────────
# PROVEEDOR LLM PRINCIPAL
# Descomenta el bloque del proveedor que uses y comenta el resto
# ──────────────────────────────────────────────────────────────

# --- OPCIÓN A: OpenAI ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
# Alternativas: gpt-4o-mini | gpt-4-turbo | gpt-3.5-turbo
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.1
# 0.0 = determinista, 1.0 = creativo — para RAG usar 0.0–0.2
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3

# --- OPCIÓN B: Anthropic Claude (descomentar si se usa) ---
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_MAX_TOKENS=2048

# --- OPCIÓN C: Google Gemini (descomentar si se usa) ---
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_MODEL=gemini-1.5-pro

# --- OPCIÓN D: Azure OpenAI (descomentar si se usa) ---
# AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://[resource-name].openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-deployment
# AZURE_OPENAI_API_VERSION=2024-02-01


# ──────────────────────────────────────────────────────────────
# MODELO DE EMBEDDINGS
# ──────────────────────────────────────────────────────────────

# Proveedor de embeddings
# Valores válidos: openai | cohere | huggingface | bedrock
EMBEDDINGS_PROVIDER=openai

# Modelo de embeddings
# OpenAI: text-embedding-3-large (3072 dims) | text-embedding-3-small (1536 dims)
# Cohere: embed-multilingual-v3.0
# HuggingFace: sentence-transformers/all-MiniLM-L6-v2
EMBEDDINGS_MODEL=text-embedding-3-small

# Dimensionalidad de los vectores (debe coincidir con la configuración del vector store)
EMBEDDINGS_DIMENSIONS=1536

# Tamaño de lote para generación de embeddings en batch
EMBEDDINGS_BATCH_SIZE=100


# ──────────────────────────────────────────────────────────────
# VECTOR STORE
# Descomenta el bloque del proveedor que uses
# ──────────────────────────────────────────────────────────────

# Proveedor del vector store
# Valores válidos: pinecone | weaviate | chromadb | pgvector | qdrant
VECTOR_DB_PROVIDER=chromadb

# --- OPCIÓN A: Pinecone (cloud managed) ---
# PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PINECONE_ENVIRONMENT=us-east-1-aws
# PINECONE_INDEX_NAME=ai-llm-project-index
# PINECONE_NAMESPACE=default

# --- OPCIÓN B: Weaviate ---
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# WEAVIATE_CLASS_NAME=Document

# --- OPCIÓN C: ChromaDB (local — recomendado para desarrollo) ---
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_COLLECTION_NAME=ai_llm_documents
# Ruta local si se usa en modo persistente sin Docker
# CHROMADB_PERSIST_PATH=./data/chromadb

# --- OPCIÓN D: pgvector (extensión de PostgreSQL) ---
# Usa la misma DATABASE_URL de abajo — pgvector se configura como extensión

# --- OPCIÓN E: Qdrant ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# QDRANT_COLLECTION_NAME=ai_llm_documents


# ──────────────────────────────────────────────────────────────
# CONFIGURACIÓN RAG (Retrieval-Augmented Generation)
# ──────────────────────────────────────────────────────────────

# Número de fragmentos recuperados por consulta (top-k)
RAG_TOP_K=5

# Score mínimo de similitud para incluir un fragmento (0.0–1.0)
# Fragmentos con score menor se descartan para evitar ruido
RAG_SIMILARITY_THRESHOLD=0.75

# Tamaño de chunks en caracteres para la división de documentos
RAG_CHUNK_SIZE=1000

# Overlap entre chunks para preservar contexto en los bordes
RAG_CHUNK_OVERLAP=200

# Estrategia de chunking
# Valores válidos: recursive | character | sentence | semantic
RAG_CHUNKING_STRATEGY=recursive

# Activar re-ranking de resultados recuperados (requiere Cohere o Colbert)
RAG_ENABLE_RERANKING=false
# COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Solo si RAG_ENABLE_RERANKING=true


# ──────────────────────────────────────────────────────────────
# BASE DE DATOS RELACIONAL
# ──────────────────────────────────────────────────────────────

# Cadena de conexión principal
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://dev_user:dev_password@postgres:5432/ai_llm_dev

# Configuración del pool de conexiones
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Credenciales individuales (usadas por docker-compose)
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=ai_llm_dev


# ──────────────────────────────────────────────────────────────
# AUTENTICACIÓN Y SEGURIDAD
# ──────────────────────────────────────────────────────────────

# Mecanismo de autenticación
# Valores válidos: jwt | api_key | oauth2
AUTH_MECHANISM=jwt

# --- JWT ---
# Clave secreta para firmar tokens JWT
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambia-esto-por-una-clave-secreta-de-minimo-32-caracteres
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- API Key (alternativa a JWT) ---
# API_KEY=ak-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OAuth2 / OIDC (descomentar si se usa proveedor externo) ---
# OAUTH2_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# OAUTH2_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# OAUTH2_AUTHORITY=https://login.microsoftonline.com/[tenant-id]
# OAUTH2_AUDIENCE=api://[app-id]

# CORS — Orígenes permitidos (separados por coma)
# En producción, especificar dominios exactos en lugar de *
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000


# ──────────────────────────────────────────────────────────────
# CLOUD PROVIDER
# Descomenta el bloque del proveedor que uses
# ──────────────────────────────────────────────────────────────

# --- OPCIÓN A: AWS ---
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_DEFAULT_REGION=us-east-1
# AWS_S3_BUCKET_NAME=ai-llm-project-documents

# --- OPCIÓN B: Azure ---
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=ai-llm-documents
# AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- OPCIÓN C: GCP ---
# GCP_PROJECT_ID=my-project-id
# GCP_STORAGE_BUCKET=ai-llm-project-documents
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# ──────────────────────────────────────────────────────────────
# OBSERVABILIDAD Y MONITOREO
# ──────────────────────────────────────────────────────────────

# --- Langfuse (trazabilidad LLM — recomendado) ---
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com
# Para instancia self-hosted: LANGFUSE_HOST=http://localhost:3000

# Activar/desactivar trazabilidad LLM
LANGFUSE_ENABLED=true

# --- LangSmith (alternativa a Langfuse) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=ai-llm-project

# --- Prometheus (métricas) ---
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# --- Sentry (error tracking en producción) ---
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1


# ──────────────────────────────────────────────────────────────
# CONFIGURACIÓN DEL PIPELINE DE INGESTA
# ──────────────────────────────────────────────────────────────

# Directorio local de documentos a ingestar (en desarrollo)
INGEST_SOURCE_DIR=./data/documents

# Tipos de archivo soportados (separados por coma)
INGEST_SUPPORTED_EXTENSIONS=.pdf,.txt,.docx,.md,.html

# Tamaño máximo de archivo a procesar (en MB)
INGEST_MAX_FILE_SIZE_MB=50

# Número de workers paralelos para la ingesta
INGEST_PARALLEL_WORKERS=4


# ──────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE PRUEBAS
# Solo se usa cuando ENVIRONMENT=testing
# ──────────────────────────────────────────────────────────────

# Base de datos de pruebas (separada de la de desarrollo)
TEST_DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/ai_llm_test

# Usar mocks en lugar de llamadas reales a APIs LLM en tests
# Ahorra costos durante la ejecución del CI
USE_LLM_MOCK=true

# Temperatura fija para reproducibilidad en tests
TEST_LLM_TEMPERATURE=0.0
